{
  "name": "@abijith-suresh/minions-opencode",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Delegation-first agent workflow plugin for OpenCode.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abijith-suresh/minions.git",
    "directory": "packages/opencode"
  },
  "homepage": "https://github.com/abijith-suresh/minions#readme",
  "bugs": {
    "url": "https://github.com/abijith-suresh/minions/issues"
  },
  "keywords": [
    "ai-agents",
    "coding-agent",
    "opencode",
    "opencode-plugin"
  ],
  "exports": {
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./tui": {
      "types": "./dist/tui.d.ts",
      "default": "./dist/tui.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": "^22.22.2 || >=24.15.0",
    "opencode": ">=1.4.0 <2"
  },
  "scripts": {
    "prebuild": "npm run build --workspace @minions/core",
    "build": "npm run clean && tsc -p tsconfig.json && node scripts/bundle.mjs",
    "clean": "node --eval \"fs.rmSync('dist', { force: true, recursive: true })\"",
    "prepack": "npm run build",
    "pretest": "npm run build --workspace @minions/core",
    "test": "vitest run",
    "test:host": "node test/opencode-host.mjs",
    "test:smoke": "node test/packed-package.mjs",
    "pretypecheck": "npm run build --workspace @minions/core",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "verify": "npm run typecheck && npm run test && npm run build && npm run test:smoke"
  },
  "devDependencies": {
    "@minions/core": "*",
    "@opencode-ai/plugin": "1.17.13",
    "esbuild": "0.28.1"
  }
}
