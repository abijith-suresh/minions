---
import SiteLayout from "../components/SiteLayout.astro";
import "../styles/global.css";

const sourceUrl = "https://github.com/abijith-suresh/minions";
const contributingUrl = "https://github.com/abijith-suresh/minions/blob/main/docs/CONTRIBUTING.md";
---

<SiteLayout
  title="Minions — agent management for OpenCode"
  description="A pre-v1 OpenCode plugin for managing agents, subagents, models, prompts, and permissions from one TUI."
>
  <header class="site-header">
    <a class="wordmark" href={import.meta.env.BASE_URL} aria-label="Minions home">
      <span aria-hidden="true">m/</span>
      minions
    </a>
    <nav aria-label="Primary">
      <a href="#workflow">Manager</a>
      <a href="#status">Status</a>
      <a href={sourceUrl}>Source ↗</a>
    </nav>
  </header>

  <main id="main-content">
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero-copy">
        <p class="kicker"><span>OpenCode plugin</span><span>pre-v1 / private</span></p>
        <h1 id="hero-title">Manage<br>the agents.<br><em>Keep control.</em></h1>
        <p class="hero-summary">
          Minions is becoming a TUI-first control panel for OpenCode agents, subagents, models,
          prompts, permissions, and explicit delegation workflows.
        </p>
        <div class="hero-actions">
          <a class="primary-link" href={sourceUrl}
            >View the source <span aria-hidden="true">↗</span></a
          >
          <span class="availability">No public install yet</span>
        </div>
      </div>

      <section class="dispatch-board" aria-label="A diagram of the Minions agent manager">
        <div class="board-heading">
          <span>dispatch / 001</span>
          <span class="status-light"><i aria-hidden="true"></i> pivot in progress</span>
        </div>
        <ol class="dispatch-flow">
          <li class="dispatch-node primary-node">
            <span class="node-index">01</span>
            <div>
              <strong>/minions</strong>
              <small>TUI control panel</small>
            </div>
            <span class="node-action">opens</span>
          </li>
          <li class="dispatch-connector" aria-hidden="true">
            <span>managed state</span><i></i>
          </li>
          <li class="dispatch-node worker-node">
            <span class="node-index">02</span>
            <div>
              <strong>agents</strong>
              <small>built-in · user · Minions-managed</small>
            </div>
            <span class="node-action">configure</span>
          </li>
          <li class="dispatch-connector returning" aria-hidden="true">
            <span>runtime injection</span><i></i>
          </li>
          <li class="dispatch-node output-node">
            <span class="node-index">03</span>
            <div>
              <strong>OpenCode</strong>
              <small>native execution</small>
            </div>
            <span class="node-action">runs</span>
          </li>
        </ol>
        <p class="board-footnote">
          Minions manages configuration; OpenCode remains responsible for execution.
        </p>
      </section>
    </section>

    <section class="principle-strip" aria-label="Project principles">
      <p>one command</p>
      <span aria-hidden="true">×</span>
      <p>many agents</p>
      <span aria-hidden="true">×</span>
      <p>clear ownership</p>
    </section>

    <section class="workflow section-shell" id="workflow" aria-labelledby="workflow-title">
      <div class="section-intro">
        <p class="section-number">01 / workflow</p>
        <h2 id="workflow-title">A control panel for agents.</h2>
        <p>
          Minions is moving agent setup out of scattered config files and into one OpenCode TUI
          flow. Delegation remains available, but as an explicit workflow rather than a mandatory
          primary-agent replacement.
        </p>
      </div>

      <ol class="workflow-list">
        <li>
          <span class="step-number">01</span>
          <div>
            <h3>Frame</h3>
            <p>Inspect built-in, user-configured, and Minions-managed agents in one place.</p>
          </div>
          <span class="role-tag primary">inspect</span>
        </li>
        <li>
          <span class="step-number">02</span>
          <div>
            <h3>Execute</h3>
            <p>Configure models, prompts, visibility, permissions, and subagent access.</p>
          </div>
          <span class="role-tag worker">manage</span>
        </li>
        <li>
          <span class="step-number">03</span>
          <div>
            <h3>Verify</h3>
            <p>Apply Minions-owned state at runtime while OpenCode keeps native execution.</p>
          </div>
          <span class="role-tag primary">apply</span>
        </li>
      </ol>
    </section>

    <section class="boundaries section-shell" aria-labelledby="boundaries-title">
      <div class="section-intro">
        <p class="section-number">02 / boundaries</p>
        <h2 id="boundaries-title">Small surface.<br>Explicit ownership.</h2>
      </div>

      <div class="boundary-grid">
        <article>
          <span class="card-mark" aria-hidden="true">A</span>
          <h3>One command</h3>
          <p>
            <code>/minions</code>{" "}is the intended public control surface. Agent-management
            actions live inside the TUI instead of many slash commands.
          </p>
        </article>
        <article>
          <span class="card-mark" aria-hidden="true">B</span>
          <h3>Managed subagents</h3>
          <p>
            The default Minions subagent is <code>minion</code>. Delegation uses it only when the
            user explicitly invokes the workflow.
          </p>
        </article>
        <article>
          <span class="card-mark" aria-hidden="true">C</span>
          <h3>Host-native execution</h3>
          <p>
            Minions injects managed configuration at runtime. Foreground, background, and task
            execution still follow what OpenCode supports.
          </p>
        </article>
      </div>
    </section>

    <section class="status-section section-shell" id="status" aria-labelledby="status-title">
      <div class="section-intro">
        <p class="section-number">03 / field status</p>
        <h2 id="status-title">Under active construction.</h2>
        <p>
          Minions is private and pre-v1. The earlier delegation prototype is being rewritten into an
          agent manager before the first public release.
        </p>
      </div>

      <div class="status-ledger">
        <div>
          <span class="ledger-state defined">defined</span>
          <p>Agent-manager product direction</p>
        </div>
        <div>
          <span class="ledger-state defined">defined</span>
          <p>OpenCode v1 as the first host</p>
        </div>
        <div>
          <span class="ledger-state planned">planned</span>
          <p>Single /minions TUI control panel</p>
        </div>
        <div>
          <span class="ledger-state withheld">withheld</span>
          <p>Installation instructions until usable</p>
        </div>
      </div>
    </section>

    <section class="closing section-shell" aria-labelledby="closing-title">
      <p class="section-number">04 / participate</p>
      <h2 id="closing-title">Follow the build,<br>not the hype.</h2>
      <p>
        The repository is open for inspection while the package remains private. Read the
        implementation, review decisions, or contribute through the project guidelines.
      </p>
      <div class="closing-links">
        <a class="closing-link" href={sourceUrl}>Source code <span aria-hidden="true">↗</span></a>
        <a class="closing-link" href={contributingUrl}
          >Contributing guide <span aria-hidden="true">↗</span></a
        >
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <span>Minions / OpenCode</span>
    <span>MIT licensed</span>
    <span>pre-v1</span>
  </footer>
</SiteLayout>
