---
import plexMonoUrl from "../assets/fonts/IBMPlexMono-Regular.woff2";
import plexSansUrl from "../assets/fonts/IBMPlexSansVar-Roman.woff2";

export interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const base = import.meta.env.BASE_URL;
const canonical = new URL(base, Astro.site);
const schema = JSON.stringify(
  {
    "@context": "https://schema.org",
    "@type": "SoftwareSourceCode",
    name: "Minions",
    description,
    codeRepository: "https://github.com/abijith-suresh/minions",
    programmingLanguage: "TypeScript",
    runtimePlatform: "OpenCode",
    url: canonical.href,
  },
  null,
  2,
);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <meta name="description" content={description}>
    <meta name="generator" content={Astro.generator}>
    <meta name="theme-color" content="#151713">
    <meta name="color-scheme" content="dark">
    <link rel="canonical" href={canonical}>
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`}>
    <link rel="preload" as="font" type="font/woff2" crossorigin="anonymous" href={plexSansUrl}>
    <link rel="preload" as="font" type="font/woff2" crossorigin="anonymous" href={plexMonoUrl}>
    <title>{title}</title>
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:type" content="website">
    <meta property="og:url" content={canonical.href}>
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content={title}>
    <meta name="twitter:description" content={description}>
    <script type="application/ld+json" is:inline set:html={schema} />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <slot />
  </body>
</html>
